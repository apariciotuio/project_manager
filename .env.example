# =========================================================================
# Work Maturation Platform — environment template
# Copy to .env and fill values. NEVER commit .env.
#
# Port map (host perspective, ≥17000):
#   17000 postgres | 17004 backend | 17005 frontend
#   17006 dundun-fake (reserved) | 17007 puppet-fake (reserved)
# =========================================================================

# --- App ---
APP_ENV=dev                              # dev | staging | prod
APP_DEBUG=true
APP_LOG_LEVEL=INFO
APP_BASE_URL=http://localhost:17004

# --- Database (Postgres 16) ---
# Used for app data AND as Celery broker/backend (no Redis).
DATABASE_URL=postgresql+asyncpg://wmp:wmp@localhost:17000/wmp
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --- Celery (Postgres-backed; real broker decision lands at M2) ---
CELERY_BROKER_URL=sqla+postgresql+psycopg://wmp:wmp@localhost:17000/wmp
CELERY_RESULT_BACKEND=db+postgresql+psycopg://wmp:wmp@localhost:17000/wmp
CELERY_TASK_ALWAYS_EAGER=true            # keep true until M2 decides broker

# --- Auth (Google OAuth + JWT) ---
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
AUTH_JWT_SECRET=change-me-in-prod
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_EXPIRE_MINUTES=60
AUTH_ALLOWED_DOMAINS=tuio.com

# --- Superadmin bootstrap (EP-00) ---
AUTH_SEED_SUPERADMIN_EMAILS=             # comma-separated

# --- Dundun (AI layer) ---
DUNDUN_BASE_URL=http://localhost:17006   # fake in dev
DUNDUN_API_KEY=dev-fake-key
DUNDUN_USE_FAKE=true
DUNDUN_CALLBACK_URL=http://localhost:17004/api/v1/dundun/callback

# --- Puppet (RAG / search) ---
PUPPET_BASE_URL=http://localhost:17007   # fake in dev
PUPPET_API_KEY=dev-fake-key
PUPPET_USE_FAKE=true

# --- Jira (integration — EP-11) ---
JIRA_BASE_URL=
JIRA_ENCRYPTION_KEY=                     # Fernet key for stored credentials

# --- CORS ---
APP_CORS_ALLOWED_ORIGINS=http://localhost:17005

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:17004
NEXT_PUBLIC_DEFAULT_LOCALE=es
